@page
@model TruePal.Api.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-body">
                    <h2 class="card-title mb-4">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </h2>
                    
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle me-2"></i>
                        Welcome back, <strong>@Model.Username</strong>!
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-4 mb-3">
                            <div class="card bg-primary text-white">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <i class="bi bi-people-fill me-2"></i>Friends
                                    </h5>
                                    <h2 class="mb-0">0</h2>
                                    <small>Total connections</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card bg-success text-white">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <i class="bi bi-file-post-fill me-2"></i>Posts
                                    </h5>
                                    <h2 class="mb-0">0</h2>
                                    <small>Content shared</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="card bg-info text-white">
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <i class="bi bi-heart-fill me-2"></i>Likes
                                    </h5>
                                    <h2 class="mb-0">0</h2>
                                    <small>Engagement received</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info mt-4">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Coming Soon:</strong> Posts, friends management, and more features!
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
