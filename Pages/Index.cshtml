            zoom: 5.8,
            pitch: 55,
            bearing: -10,
            antialias: true,
            attributionControl: false
        });

        map.addControl(new maplibregl.AttributionControl({ compact: true }), 'bottom-left');
        map.addControl(new maplibregl.NavigationControl({ visualizePitch: true }), 'top-right');

        // ===== LOCATIONS =====
        const locations = [
