@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

@section Styles {
    <!-- MapLibre GL JS — free, no API key needed -->
    <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet">
    <style>
        /* Override layout padding for immersive map */
        main[role="main"] {
            padding: 0 !important;
        }

        /* ===== HERO MAP SECTION ===== */
        .map-hero {
            position: relative;
            width: 100%;
            height: calc(100vh - 62px);
            overflow: hidden;
        }

        #philippine-map {
            width: 100%;
            height: 100%;
        }

        /* ===== OVERLAY HEADER ===== */
        .map-overlay-header {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            text-align: center;
            pointer-events: none;
        }

        .map-overlay-header h1 {
            font-size: 2rem;
            font-weight: 800;
            color: #fff;
            text-shadow: 0 2px 20px rgba(0,0,0,0.5);
            margin: 0;
            letter-spacing: -0.5px;
        }

        .map-overlay-header p {
            color: rgba(255,255,255,0.85);
            font-size: 0.95rem;
            text-shadow: 0 1px 8px rgba(0,0,0,0.4);
            margin: 4px 0 0;
        }

        /* ===== REGION CHIPS (bottom of map) ===== */
        .region-chips {
            position: absolute;
            bottom: 24px;
            left: 0;
            right: 0;
            z-index: 10;
            display: flex;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
            padding: 0 20px;
            pointer-events: none;
        }

        .region-chip {
            pointer-events: all;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(201,169,97,0.3);
            color: #333;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            white-space: nowrap;
        }

        .region-chip:hover,
        .region-chip.active {
            background: var(--primary-yellow);
            color: #fff;
            border-color: var(--primary-yellow);
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(201,169,97,0.4);
        }

        /* ===== MARKER PINS ===== */
        .map-pin {
            position: relative;
            width: 40px;
            height: 40px;
            cursor: pointer;
            transition: transform 0.3s ease;
            filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
        }

        .map-pin:hover {
            transform: scale(1.2);
        }

        .map-pin-inner {
            width: 40px;
            height: 40px;
            background: var(--primary-yellow);
            border-radius: 50% 50% 50% 0;
            transform: rotate(-45deg);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid #fff;
            box-shadow: 0 2px 12px rgba(201,169,97,0.5);
        }

        .map-pin-inner i {
            transform: rotate(45deg);
            color: #fff;
            font-size: 1rem;
        }

        .map-pin-pulse {
            position: absolute;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(201,169,97,0.3);
            animation: pulse-ring 2s ease-out infinite;
            top: 0;
            left: 0;
        }

        @@keyframes pulse-ring {
            0% { transform: scale(0.8); opacity: 1; }
            100% { transform: scale(2.2); opacity: 0; }
        }

        /* ===== POSTS SIDE PANEL ===== */
        .posts-panel {
            position: absolute;
            top: 0;
            right: 0;
            width: 420px;
            height: 100%;
            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            z-index: 20;
            transform: translateX(100%);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            box-shadow: -8px 0 40px rgba(0,0,0,0.15);
        }

        .posts-panel.open {
            transform: translateX(0);
        }

        .posts-panel-header {
            padding: 20px 24px 16px;
            border-bottom: 1px solid rgba(201,169,97,0.2);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }

        .posts-panel-header h4 {
            margin: 0;
            font-weight: 700;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .posts-panel-close {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: var(--primary-yellow-light);
            color: var(--primary-yellow);
            font-size: 1.2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s ease;
        }

        .posts-panel-close:hover {
            background: var(--primary-yellow);
            color: #fff;
        }

        .posts-panel-subtitle {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 2px;
        }

        .posts-panel-body {
            flex: 1;
            overflow-y: auto;
            padding: 16px 24px;
        }

        /* ===== POST CARDS ===== */
        .flex-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 16px;
            border: 1px solid #eee;
            transition: all 0.3s ease;
        }

        .flex-card:hover {
            border-color: var(--primary-yellow);
            box-shadow: 0 8px 24px rgba(201,169,97,0.15);
            transform: translateY(-2px);
        }

        .flex-card-image {
            width: 100%;
            height: 160px;
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .flex-card-image-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 12px;
            background: linear-gradient(transparent, rgba(0,0,0,0.6));
        }

        .flex-card-image-overlay .badge {
            background: var(--primary-yellow);
            color: #fff;
            font-size: 0.7rem;
            padding: 4px 10px;
            border-radius: 12px;
            font-weight: 600;
        }

        .flex-card-body {
            padding: 14px 16px;
        }

        .flex-card-user {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .flex-card-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-yellow), var(--primary-yellow-dark));
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 0.85rem;
            flex-shrink: 0;
        }

        .flex-card-name {
            font-weight: 700;
            font-size: 0.9rem;
            color: #333;
        }

        .flex-card-time {
            font-size: 0.75rem;
            color: #999;
        }

        .flex-card-content {
            font-size: 0.9rem;
            line-height: 1.5;
            color: #444;
            margin-bottom: 12px;
        }

        .flex-card-actions {
            display: flex;
            gap: 16px;
            padding-top: 10px;
            border-top: 1px solid #f0f0f0;
        }

        .flex-card-action {
            background: none;
            border: none;
            color: #888;
            font-size: 0.8rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 0;
            transition: color 0.2s;
        }

        .flex-card-action:hover {
            color: var(--primary-yellow);
        }

        .flex-card-action .count {
            font-weight: 600;
        }

        /* ===== EMPTY STATE ===== */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
        }

        .empty-state i {
            font-size: 3rem;
            color: var(--primary-yellow);
            opacity: 0.5;
        }

        .empty-state p {
            color: #999;
            margin-top: 12px;
            font-size: 0.9rem;
        }

        /* ===== AUTH OVERLAY (not logged in) ===== */
        .auth-overlay {
            position: absolute;
            bottom: 80px;
            left: 20px;
            z-index: 10;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 20px;
            padding: 24px 28px;
            max-width: 340px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.15);
            border: 1px solid rgba(201,169,97,0.2);
        }

        .auth-overlay h2 {
            font-size: 1.4rem;
            font-weight: 800;
            margin: 0 0 6px;
            color: #333;
        }

        .auth-overlay p {
            font-size: 0.85rem;
            color: #666;
            margin: 0 0 16px;
            line-height: 1.4;
        }

        .auth-overlay .btn-group-auth {
            display: flex;
            gap: 10px;
        }

        .auth-overlay .btn {
            border-radius: 12px;
            font-weight: 600;
            padding: 8px 20px;
            font-size: 0.85rem;
        }

        /* ===== MAP CONTROLS OVERRIDE ===== */
        .maplibregl-ctrl-group {
            border-radius: 12px !important;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(0,0,0,0.12) !important;
        }

        .maplibregl-ctrl-group button {
            width: 36px !important;
            height: 36px !important;
        }

        .maplibregl-ctrl-top-right {
            top: 70px !important;
            right: 12px !important;
        }

        .maplibregl-ctrl-attrib {
            background: rgba(255,255,255,0.6) !important;
            border-radius: 8px !important;
            font-size: 0.65rem !important;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 768px) {
            .posts-panel {
                width: 100%;
                border-radius: 20px 20px 0 0;
                height: 60%;
                top: auto;
                bottom: 0;
                transform: translateY(100%);
            }
            .posts-panel.open {
                transform: translateY(0);
            }
            .map-overlay-header h1 {
                font-size: 1.4rem;
            }
            .region-chips {
                bottom: 16px;
                gap: 6px;
            }
            .region-chip {
                font-size: 0.7rem;
                padding: 5px 10px;
            }
            .auth-overlay {
                left: 12px;
                right: 12px;
                bottom: 60px;
                max-width: none;
            }
        }
    </style>
}

<!-- FULL-SCREEN MAP HERO -->
<div class="map-hero">
    <div id="philippine-map"></div>

    <div class="map-overlay-header">
        <h1>Explore the Philippines</h1>
        <p>Tap a pin to see what people are flexing about</p>
    </div>

    @if (!Model.IsAuthenticated)
    {
        <div class="auth-overlay">
            <h2>Join TruePal</h2>
            <p>Connect with travelers and share your favorite spots across the Philippines.</p>
            <div class="btn-group-auth">
                <a asp-page="/Auth/Login" class="btn btn-primary">Log In</a>
                <a asp-page="/Auth/Register" class="btn btn-outline-primary">Sign Up</a>
            </div>
        </div>
    }

    <div class="region-chips" id="region-chips"></div>

    <!-- Slide-out Posts Panel -->
    <div class="posts-panel" id="posts-panel">
        <div class="posts-panel-header">
            <div>
                <h4>
                    <i class="bi bi-geo-alt-fill" style="color: var(--primary-yellow);"></i>
                    <span id="panel-region-name">Region</span>
                </h4>
                <div class="posts-panel-subtitle" id="panel-post-count">0 posts</div>
            </div>
            <button class="posts-panel-close" id="close-panel" title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="posts-panel-body" id="posts-list"></div>
    </div>
</div>

@section Scripts {
    <!-- MapLibre GL JS — free, open-source, no token -->
