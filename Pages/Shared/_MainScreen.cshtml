@model IndexModel

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-8 text-center">
            <div class="card shadow">
                <div class="card-body p-5">
                    <i class="bi bi-heart-fill text-primary" style="font-size: 4rem;"></i>
                    <h1 class="display-4 mb-4 mt-3">Welcome to TruePal</h1>
                    <p class="lead mb-4">Your social platform for connecting with friends and building meaningful relationships</p>
                    
                    @if (Model.IsAuthenticated)
                    {
                        <div class="d-flex gap-3 justify-content-center">
                            <a asp-page="/Dashboard/Index" class="btn btn-primary btn-lg">
                                <i class="bi bi-speedometer2 me-2"></i>Go to Dashboard
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-3 justify-content-center">
                            <a asp-page="/Auth/Login" class="btn btn-primary btn-lg">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Login
                            </a>
                            <a asp-page="/Auth/Register" class="btn btn-outline-primary btn-lg">
                                <i class="bi bi-person-plus me-2"></i>Sign Up
                            </a>
                        </div>
                    }
                    
                    <div class="row mt-5">
                        <div class="col-md-4">
                            <i class="bi bi-people-fill text-primary" style="font-size: 2rem;"></i>
                            <h5 class="mt-2">Connect</h5>
                            <p class="text-muted">Meet new people and build your network</p>
                        </div>
                        <div class="col-md-4">
                            <i class="bi bi-chat-dots-fill text-primary" style="font-size: 2rem;"></i>
                            <h5 class="mt-2">Share</h5>
                            <p class="text-muted">Share your thoughts and moments</p>
                        </div>
                        <div class="col-md-4">
                            <i class="bi bi-heart-fill text-primary" style="font-size: 2rem;"></i>
                            <h5 class="mt-2">Grow</h5>
                            <p class="text-muted">Build meaningful relationships</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
