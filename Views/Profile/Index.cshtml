@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="container">
    <div class="row">
        <!-- Left Sidebar - Profile Card -->
        <div class="col-md-4 mb-4">
            <div class="card shadow sticky-sidebar">
                <div class="card-body text-center">
                    <div class="profile-avatar mb-3">
                        <i class="bi bi-person-circle icon-xl text-primary"></i>
                    </div>
                    <h3 class="mb-1">@Model.Username</h3>
                    <p class="text-muted mb-3">@Model.Email</p>
                    
                    <hr>
                    
                    <div class="text-start mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-calendar3 me-2 text-primary"></i>
                            <small class="text-muted">
                                Joined @Model.CreatedAt.ToString("MMMM yyyy")
                            </small>
                        </div>
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-envelope me-2 text-primary"></i>
                            <small class="text-muted">@Model.Email</small>
                        </div>
                    </div>
                    
                    <hr>
                    
                    <div class="d-grid gap-2">
                        <a href="#" class="btn btn-primary">
                            <i class="bi bi-pencil-square me-2"></i>Edit Profile
                        </a>
                        <a href="#" class="btn btn-outline-primary">
                            <i class="bi bi-shield-lock me-2"></i>Change Password
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Content - Tabs -->
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body">
                    <!-- Tabs Navigation -->
                    <ul class="nav nav-tabs mb-4" id="profileTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">
                                <i class="bi bi-person me-1"></i>Overview
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="wimf-tab" data-bs-toggle="tab" data-bs-target="#wimf" type="button" role="tab">
                                <i class="bi bi-geo-alt me-1"></i>Where I'm From
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="posts-tab" data-bs-toggle="tab" data-bs-target="#posts" type="button" role="tab">
                                <i class="bi bi-card-text me-1"></i>Posts
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">
                                <i class="bi bi-gear me-1"></i>Settings
                            </button>
                        </li>
                    </ul>

                    <!-- Tabs Content -->
                    <div class="tab-content" id="profileTabsContent">
                        <!-- Overview Tab -->
                        <div class="tab-pane fade show active" id="overview" role="tabpanel">
                            <h4 class="mb-4"><i class="bi bi-info-circle me-2 text-primary"></i>About</h4>
                            
                            <div class="mb-4">
                                <h6 class="text-muted mb-2">Bio</h6>
                                <p>Welcome to my TruePal profile! Connect with me to learn more.</p>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-6">
                                    <div class="card bg-light">
                                        <div class="card-body text-center">
                                            <h3 class="text-primary mb-0">@Model.TotalPosts</h3>
                                            <small class="text-muted">Posts</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="card bg-light">
                                        <div class="card-body text-center">
                                            <h3 class="text-primary mb-0">0</h3>
                                            <small class="text-muted">Friends</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr>

                            <h6 class="text-muted mb-3">Quick Info</h6>
                            <div class="list-group list-group-flush">
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-person me-2 text-primary"></i>Username</span>
                                    <strong>@Model.Username</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-envelope me-2 text-primary"></i>Email</span>
                                    <strong>@Model.Email</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-calendar-check me-2 text-primary"></i>Member Since</span>
                                    <strong>@Model.CreatedAt.ToString("MMM dd, yyyy")</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Where I'm From Tab -->
                        <div class="tab-pane fade" id="wimf" role="tabpanel">
                            <h4 class="mb-4"><i class="bi bi-geo-alt me-2 text-primary"></i>Where I'm From</h4>
                            
                            <div class="text-center py-4 mb-4">
                                <i class="bi bi-map icon-lg text-accent"></i>
                            </div>

                            <form>
                                <div class="mb-3">
                                    <label for="country" class="form-label"><i class="bi bi-flag me-2"></i>Country</label>
                                    <input type="text" class="form-control" id="country" placeholder="e.g. United States">
                                </div>
                                <div class="mb-3">
                                    <label for="city" class="form-label"><i class="bi bi-building me-2"></i>City</label>
                                    <input type="text" class="form-control" id="city" placeholder="e.g. New York">
                                </div>
                                <div class="mb-3">
                                    <label for="hometown" class="form-label"><i class="bi bi-house-heart me-2"></i>Hometown</label>
                                    <input type="text" class="form-control" id="hometown" placeholder="Where did you grow up?">
                                </div>
                                <div class="mb-3">
                                    <label for="story" class="form-label"><i class="bi bi-book me-2"></i>My Story</label>
                                    <textarea class="form-control" id="story" rows="4" placeholder="Tell us about where you're from..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save me-2"></i>Save Location Info
                                </button>
                            </form>
                        </div>

                        <!-- Posts Tab -->
                        <div class="tab-pane fade" id="posts" role="tabpanel">
                            <h4 class="mb-4"><i class="bi bi-card-text me-2 text-primary"></i>My Posts</h4>
                            
                            @if (Model.YourPosts.Any())
                            {
                                <div class="mb-3 text-end">
                                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPostModal">
                                        <i class="bi bi-plus-circle me-2"></i>Create Post
                                    </button>
                                </div>
                                
                                <div class="list-group">
                                    @foreach (var post in Model.YourPosts)
                                    {
                                        <div class="list-group-item">
                                            <div class="d-flex w-100 justify-content-between align-items-start mb-2">
                                                <div>
                                                    <h5 class="mb-1">
                                                        @if (!string.IsNullOrEmpty(post.Location))
                                                        {
                                                            <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                                                            <span>@post.Location</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-chat-left-text text-primary me-1"></i>
                                                            <span>Post</span>
                                                        }
                                                    </h5>
                                                    <small class="text-muted">@post.TimeAgo</small>
                                                </div>
                                                <div class="btn-group btn-group-sm">
                                                    <button class="btn btn-outline-secondary" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                            
                                            <p class="mb-2">@post.Content</p>
                                            
                                            @if (!string.IsNullOrEmpty(post.ImageUrl))
                                            {
                                                <div class="mb-2">
                                                    <img src="@post.ImageUrl" alt="Post image" class="img-fluid rounded post-image-preview">
                                                </div>
                                            }
                                            
                                            <div class="d-flex gap-3 text-muted">
                                                <small>
                                                    <i class="bi bi-heart me-1"></i>
                                                    @post.LikesCount @(post.LikesCount == 1 ? "like" : "likes")
                                                </small>
                                                <small>
                                                    <i class="bi bi-chat me-1"></i>
                                                    @post.CommentsCount @(post.CommentsCount == 1 ? "comment" : "comments")
                                                </small>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="bi bi-file-text icon-lg text-accent"></i>
                                    <p class="mt-3 text-muted">No posts yet. Start sharing your thoughts!</p>
                                    <button type="button" class="btn btn-primary mt-2" data-bs-toggle="modal" data-bs-target="#createPostModal">
                                        <i class="bi bi-plus-circle me-2"></i>Create Post
                                    </button>
                                </div>
                            }
                        </div>

                        <!-- Settings Tab -->
                        <div class="tab-pane fade" id="settings" role="tabpanel">
                            <h4 class="mb-4"><i class="bi bi-gear me-2 text-primary"></i>Account Settings</h4>
                            <div class="list-group">
                                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Profile</span>
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-shield-lock me-2 text-primary"></i>Change Password</span>
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-bell me-2 text-primary"></i>Notifications</span>
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <span><i class="bi bi-lock me-2 text-primary"></i>Privacy Settings</span>
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center text-danger">
                                    <span><i class="bi bi-trash me-2"></i>Delete Account</span>
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Post Modal -->
<partial name="Components/_CreatePostModal" />

@section Styles {
    <link rel="stylesheet" href="~/css/components/modals.css" asp-append-version="true">
}

@section Scripts {
    <script src="~/js/components/create-post-modal.js" asp-append-version="true"></script>
}
