<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TruePal</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <!-- Theme CSS -->
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true">
    
    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            display: flex;
            flex-direction: column;
            background: var(--bg-primary);
            color: var(--text-primary);
        }

        .navbar {
            background-color: var(--color-dark) !important;
            border-bottom: 3px solid var(--color-primary);
            box-shadow: var(--shadow-md);
            padding: 0.5rem 1rem;
        }

        .navbar-brand {
            color: var(--text-white) !important;
            font-weight: 700;
            transition: var(--transition-base);
        }

        .navbar-brand:hover {
            opacity: 0.9;
        }

        .navbar-nav {
            gap: var(--spacing-sm);
        }

        .nav-link {
            border-radius: var(--radius-md);
            padding: 0.4rem 0.8rem;
            transition: var(--transition-base);
            color: var(--text-white) !important;
            font-weight: 500;
            font-size: 0.9rem;
        }

        .nav-link i {
            color: var(--color-primary);
            transition: var(--transition-base);
        }

        .nav-link:hover {
            background: var(--color-dark-lighter);
            color: var(--color-primary) !important;
        }

        .nav-link:hover i {
            color: var(--color-primary);
        }

        .nav-link.active {
            background: var(--color-primary);
            color: var(--color-dark) !important;
            font-weight: 700;
            box-shadow: 0 4px 12px var(--color-primary-glow);
        }

        .nav-link.active i {
            color: var(--color-dark);
        }

        main {
            flex: 1;
            padding: var(--spacing-xl) 0;
        }

        footer {
            background-color: var(--color-dark);
            color: var(--text-white);
            padding: var(--spacing-md) 0;
            border-top: 3px solid var(--color-primary);
            box-shadow: var(--shadow-md);
            margin-top: 0;
        }

        footer i {
            color: var(--color-primary);
        }
    </style>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="TruePal" style="height: 40px; width: auto;" />
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Home
                        </a>
                    </li>
                    @if (Context.Request.Cookies.ContainsKey("AuthToken"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")" asp-controller="Profile" asp-action="Index">
                                <i class="bi bi-person-circle me-1"></i>Profile
                            </a>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-controller="Auth" asp-action="Logout" class="d-inline">
                                <button type="submit" class="btn btn-link nav-link">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Auth" && ViewContext.RouteData.Values["action"]?.ToString() == "Login" ? "active" : "")" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Auth" && ViewContext.RouteData.Values["action"]?.ToString() == "Register" ? "active" : "")" asp-controller="Auth" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <!-- Main Content -->
    <main role="main" class="pb-3 @ViewData["MainClass"]">
        <partial name="_StatusMessages" />
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="text-center">
        <div class="container">
            <p class="mb-0">&copy; 2026 TruePal. All rights reserved Bob.</p>
        </div>
    </footer>

    <!-- jQuery (required for validation) -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
