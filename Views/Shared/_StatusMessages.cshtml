@*
    TruePal Snackbar/Toast System

    Server-side: reads TempData set by BasePageModel (SuccessMessage, ErrorMessage, InfoMessage, ErrorMessages)
    Client-side: call TruePal.toast('message', 'success|error|info|warning') from any page JS
*@

<!-- Toast Container (fixed bottom-right) -->
<div id="snackbar-container" aria-live="polite" aria-atomic="true"></div>

<style>
    #snackbar-container {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column-reverse;
        gap: 10px;
        pointer-events: none;
        max-width: 400px;
    }

    .snackbar {
        pointer-events: all;
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 14px 18px;
        border-radius: 14px;
        font-size: 0.875rem;
        line-height: 1.4;
        color: #fff;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
        transform: translateX(120%);
        opacity: 0;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        max-width: 100%;
        word-break: break-word;
    }

    .snackbar.show {
        transform: translateX(0);
        opacity: 1;
    }

    .snackbar.hide {
        transform: translateX(120%);
        opacity: 0;
    }

    /* Type variants */
    .snackbar--success {
        background: linear-gradient(135deg, #2d8a4e, #1a6b37);
        border-left: 4px solid #5fdd6e;
    }

    .snackbar--error {
        background: linear-gradient(135deg, #c0392b, #96281b);
        border-left: 4px solid #f1948a;
    }

    .snackbar--info {
        background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
        border-left: 4px solid var(--color-info);
    }

    .snackbar--warning {
        background: linear-gradient(135deg, #d4a017, #b8860b);
        border-left: 4px solid #f7dc6f;
    }

    .snackbar-icon {
        font-size: 1.1rem;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .snackbar-body {
        flex: 1;
        min-width: 0;
    }

    .snackbar-body ul {
        margin: 4px 0 0;
        padding-left: 18px;
    }

    .snackbar-close {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.7);
        font-size: 1rem;
        cursor: pointer;
        padding: 0;
        flex-shrink: 0;
        margin-top: 1px;
        transition: color 0.2s;
    }

    .snackbar-close:hover {
        color: #fff;
    }

    /* Progress bar (auto-dismiss timer) */
    .snackbar-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        height: 3px;
        border-radius: 0 0 14px 14px;
        background: rgba(255, 255, 255, 0.35);
        transition: width linear;
    }

    /* Responsive */
    @@media (max-width: 576px) {
        #snackbar-container {
            left: 12px;
            right: 12px;
            bottom: 12px;
            max-width: none;
        }
    }
</style>

<script>
    // ===== TruePal Toast/Snackbar API =====
    window.TruePal = window.TruePal || {};

    (function () {
        const container = document.getElementById('snackbar-container');
        const ICONS = {
            success: 'bi-check-circle-fill',
            error:   'bi-x-circle-fill',
            info:    'bi-info-circle-fill',
            warning: 'bi-exclamation-triangle-fill'
        };
        const DURATIONS = {
            success: 4000,
            error:   6000,
            info:    4000,
            warning: 5000
        };

        /**
         * Show a snackbar toast.
         * @@param {string} message  - Text or HTML content
         * @@param {string} type     - 'success' | 'error' | 'info' | 'warning'
         * @@param {number} duration - Auto-dismiss ms (0 = manual close only)
         */
        TruePal.toast = function (message, type, duration) {
            type = type || 'info';
            duration = duration !== undefined ? duration : (DURATIONS[type] || 4000);

            const el = document.createElement('div');
            el.className = `snackbar snackbar--${type}`;
            el.setAttribute('role', 'alert');
            el.innerHTML = `
                <i class="bi ${ICONS[type] || ICONS.info} snackbar-icon"></i>
                <div class="snackbar-body">${message}</div>
                <button class="snackbar-close" aria-label="Dismiss"><i class="bi bi-x-lg"></i></button>
                ${duration > 0 ? '<div class="snackbar-progress"></div>' : ''}
            `;

            container.appendChild(el);

            // Trigger enter animation
            requestAnimationFrame(() => {
                requestAnimationFrame(() => el.classList.add('show'));
            });

            // Close button
            el.querySelector('.snackbar-close').addEventListener('click', () => dismiss(el));

            // Progress bar + auto-dismiss
            if (duration > 0) {
                const bar = el.querySelector('.snackbar-progress');
                if (bar) {
                    bar.style.width = '100%';
                    requestAnimationFrame(() => {
                        bar.style.transitionDuration = duration + 'ms';
                        bar.style.width = '0%';
                    });
                }
                el._timeout = setTimeout(() => dismiss(el), duration);

                // Pause on hover
                el.addEventListener('mouseenter', () => {
                    clearTimeout(el._timeout);
                    if (bar) {
                        const remaining = bar.getBoundingClientRect().width;
                        bar.style.transitionDuration = '0ms';
                        bar.style.width = remaining + 'px';
                    }
                });
                el.addEventListener('mouseleave', () => {
                    if (bar) {
                        const containerWidth = el.getBoundingClientRect().width;
                        const remaining = bar.getBoundingClientRect().width;
                        const pct = remaining / containerWidth;
                        const remainMs = duration * pct;
                        bar.style.transitionDuration = remainMs + 'ms';
                        bar.style.width = '0%';
                        el._timeout = setTimeout(() => dismiss(el), remainMs);
                    }
                });
            }

            return el;
        };

        function dismiss(el) {
            clearTimeout(el._timeout);
            el.classList.remove('show');
            el.classList.add('hide');
            el.addEventListener('transitionend', () => el.remove(), { once: true });
            // Fallback if transition doesn't fire
            setTimeout(() => { if (el.parentNode) el.remove(); }, 500);
        }
    })();
</script>

@using System.Text.Json

@* ===== Render server-side TempData messages on page load ===== *@
@{
    var success = TempData["SuccessMessage"]?.ToString();
    var error = TempData["ErrorMessage"]?.ToString();
    var info = TempData["InfoMessage"]?.ToString();
    var warning = TempData["WarningMessage"]?.ToString();

    // ErrorMessagesJson is a JSON-serialized List<string> from BasePageModel
    var errorsJson = TempData["ErrorMessagesJson"]?.ToString();
    List<string>? errors = null;
    if (!string.IsNullOrEmpty(errorsJson))
    {
        try { errors = JsonSerializer.Deserialize<List<string>>(errorsJson); }
        catch { /* malformed JSON — ignore */ }
    }
}

@if (!string.IsNullOrEmpty(success) || !string.IsNullOrEmpty(error) || !string.IsNullOrEmpty(info) || !string.IsNullOrEmpty(warning) || errors?.Any() == true)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            @if (!string.IsNullOrEmpty(success))
            {
                <text>TruePal.toast('@Html.Raw(success.Replace("'", "\\'"))', 'success');</text>
            }
            @if (!string.IsNullOrEmpty(error))
            {
                <text>TruePal.toast('@Html.Raw(error.Replace("'", "\\'"))', 'error');</text>
            }
            @if (!string.IsNullOrEmpty(info))
            {
                <text>TruePal.toast('@Html.Raw(info.Replace("'", "\\'"))', 'info');</text>
            }
            @if (!string.IsNullOrEmpty(warning))
            {
                <text>TruePal.toast('@Html.Raw(warning.Replace("'", "\\'"))', 'warning');</text>
            }
            @if (errors?.Any() == true)
            {
                var errorList = string.Join("", errors.Select(e => $"<li>{Html.Encode(e)}</li>"));
                <text>TruePal.toast('<ul>@Html.Raw(errorList)</ul>', 'error', 8000);</text>
            }
        });
    </script>
}
