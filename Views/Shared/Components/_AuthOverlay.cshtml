@* Reusable component for auth overlay on homepage *@

<div class="auth-overlay">
    <h2>Join TruePal</h2>
    <p>Connect with travelers and share your favorite spots across the Philippines.</p>
    <div class="btn-group-auth">
        <a asp-page="/Auth/Login" class="btn btn-primary">Log In</a>
        <a asp-page="/Auth/Register" class="btn btn-outline-primary">Sign Up</a>
    </div>
</div>
