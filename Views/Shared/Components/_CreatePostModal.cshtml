@* Reusable component for creating posts *@

<!-- Create Post Modal -->
<div class="modal fade" id="createPostModal" tabindex="-1" aria-labelledby="createPostModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createPostModalLabel">
                    <i class="bi bi-plus-circle me-2 text-primary"></i>Create Post
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="createPostForm">
                    <!-- Content Field -->
                    <div class="mb-3">
                        <label for="postContent" class="form-label">What's on your mind?</label>
                        <textarea 
                            class="form-control" 
                            id="postContent" 
                            name="content"
                            rows="4" 
                            maxlength="500"
                            placeholder="Share your thoughts, experiences, or travel stories..."
                            required></textarea>
                        <div class="form-text text-end">
                            <span id="charCount">0</span>/500 characters
                        </div>
                        <div class="invalid-feedback">
                            Please enter your post content (1-500 characters).
                        </div>
                    </div>

                    <!-- Location Field -->
                    <div class="mb-3">
                        <label for="postLocation" class="form-label">
                            <i class="bi bi-geo-alt me-1"></i>Location (Optional)
                        </label>
                        <input 
                            type="text" 
                            class="form-control" 
                            id="postLocation" 
                            name="location"
                            maxlength="200"
                            placeholder="e.g., Manila, Philippines">
                        <div class="invalid-feedback">
                            Location must be 200 characters or less.
                        </div>
                    </div>

                    <!-- Image Upload or URL -->
                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-image me-1"></i>Image (Optional)
                        </label>
                        
                        <!-- Tab Navigation -->
                        <ul class="nav nav-tabs mb-3" id="imageUploadTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="upload-tab" data-bs-toggle="tab" data-bs-target="#upload-panel" type="button" role="tab">
                                    <i class="bi bi-upload me-1"></i>Upload
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="url-tab" data-bs-toggle="tab" data-bs-target="#url-panel" type="button" role="tab">
                                    <i class="bi bi-link-45deg me-1"></i>URL
                                </button>
                            </li>
                        </ul>

                        <!-- Tab Content -->
                        <div class="tab-content" id="imageUploadTabContent">
                            <!-- Upload Panel -->
                            <div class="tab-pane fade show active" id="upload-panel" role="tabpanel">
                                <input 
                                    type="file" 
                                    class="form-control" 
                                    id="postImageFile" 
                                    name="imageFile"
                                    accept="image/jpeg,image/png,image/gif,image/webp">
                                <div class="form-text">
                                    Upload an image (JPG, PNG, GIF, WEBP, max 5MB)
                                </div>
                                <div id="imagePreviewContainer" class="mt-2 d-none">
                                    <img id="imagePreview" src="" alt="Preview" class="img-fluid rounded post-image-preview">
                                    <button type="button" class="btn btn-sm btn-danger mt-2" id="removeImageBtn">
                                        <i class="bi bi-x-circle me-1"></i>Remove
                                    </button>
                                </div>
                                <div class="invalid-feedback" id="fileUploadError"></div>
                            </div>
                            
                            <!-- URL Panel -->
                            <div class="tab-pane fade" id="url-panel" role="tabpanel">
                                <input 
                                    type="url" 
                                    class="form-control" 
                                    id="postImageUrl" 
                                    name="imageUrl"
                                    maxlength="500"
                                    placeholder="https://example.com/image.jpg">
                                <div class="form-text">
                                    Enter a direct link to an image
                                </div>
                                <div class="invalid-feedback">
                                    Please enter a valid URL (max 500 characters).
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Error Alert -->
                    <div id="createPostError" class="alert alert-danger d-none" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <span id="createPostErrorMessage"></span>
                    </div>

                    <!-- Success Alert -->
                    <div id="createPostSuccess" class="alert alert-success d-none" role="alert">
                        <i class="bi bi-check-circle me-2"></i>
                        Post created successfully!
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="createPostForm" class="btn btn-primary" id="submitPostBtn">
                    <i class="bi bi-send me-2"></i>Post
                </button>
            </div>
        </div>
    </div>
</div>
