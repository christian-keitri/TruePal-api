@* Reusable component for posts panel *@

<div class="posts-panel" id="posts-panel">
    <div class="posts-panel-header">
        <div>
            <h4>
                <i class="bi bi-geo-alt-fill" style="color: var(--primary-yellow);"></i>
                <span id="panel-region-name">Region</span>
            </h4>
            <div class="posts-panel-subtitle" id="panel-post-count">0 posts</div>
        </div>
        <button class="posts-panel-close" id="close-panel" title="Close" aria-label="Close panel">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
    <div class="posts-panel-body" id="posts-list">
        <!-- Posts will be dynamically inserted here via JavaScript -->
    </div>
</div>
