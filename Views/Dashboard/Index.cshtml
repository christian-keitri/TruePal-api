@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-container">
    <partial name="_StatsCards" model="Model" />
    <partial name="_CreatePostSection" />
    
    <!-- Main Content Grid -->
    <div class="dashboard-grid">
        <partial name="_FeedSection" model="Model" />
        <partial name="_Sidebar" model="Model" />
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true">
}

@section Scripts {
    <script type="module" src="~/js/pages/dashboard.js" asp-append-version="true"></script>
}
