@model HomeViewModel

<!-- Left Half: Map Section -->
<div class="map-section">
    <!-- Vertical Location Sidebar -->
    <div class="locations-sidebar" id="locations-sidebar"></div>
    
    <!-- Trending Button -->
    <button class="trending-btn" id="trending-btn" title="View Trending Posts">
        <i class="bi bi-fire-fill"></i>
        <span>Trending</span>
    </button>
    
    <div id="philippine-map"></div>
    
    @if (!Model.IsAuthenticated)
    {
        <partial name="Components/_AuthOverlay" />
    }
</div>
