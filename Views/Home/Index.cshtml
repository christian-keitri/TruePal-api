@model HomeViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["MainClass"] = "home-page";
}

@section Styles {
    <!-- MapLibre GL JS -->
    <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet">
    <!-- Component styles -->
    <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components/panels.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components/overlays.css" asp-append-version="true">
    <!-- Page-specific styles -->
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true">
}

<div class="split-layout">
    <!-- Left Half: Map -->
    <partial name="_MapSection" model="Model" />
    
    <!-- Right Half: Details -->
    <partial name="_DetailsSection" model="Model" />
</div>

@section Scripts {
    <!-- MapLibre GL JS — free, open-source, no token -->
    <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
    
    <!-- TruePal App Scripts (ES6 Modules) -->
    <script type="module" src="~/js/pages/home.js" asp-append-version="true"></script>
}
