@model HomeViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["MainClass"] = "home-page";
}

@section Styles {
    <!-- MapLibre GL JS -->
    <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet">
    <!-- Component styles -->
    <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components/panels.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components/overlays.css" asp-append-version="true">
    <!-- Page-specific styles -->
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true">
}

<div class="split-layout">
    <!-- Left Half: Map -->
    <div class="map-section">
        <div id="philippine-map"></div>
        
        @if (!Model.IsAuthenticated)
        {
            <partial name="Components/_AuthOverlay" />
        }
        
        <div class="region-chips" id="region-chips"></div>
    </div>
    
    <!-- Right Half: Details -->
    <div class="details-section">
        <div class="details-header">
            <h2 id="location-title">
                <i class="bi bi-geo-alt-fill me-2"></i>
                Explore the Philippines
            </h2>
            <p class="text-muted" id="location-subtitle">Click any location on the map or chip below to see posts</p>
        </div>
        
        <div class="details-content" id="posts-container">
            <!-- Welcome message when no location selected -->
            <div class="welcome-message" id="welcome-message">
                <i class="bi bi-map" style="font-size: 4rem; color: var(--color-primary); margin-bottom: 1rem;"></i>
                <h3>Discover Amazing Places</h3>
                <p class="text-muted">Select a location from the map to see posts, photos, and stories from travelers.</p>
                <div class="featured-locations mt-4">
                    <h5 class="mb-3">Popular Destinations</h5>
                    <div class="location-grid">
                        <span class="location-badge"><i class="bi bi-umbrella"></i> Boracay</span>
                        <span class="location-badge"><i class="bi bi-gem"></i> El Nido</span>
                        <span class="location-badge"><i class="bi bi-tsunami"></i> Siargao</span>
                        <span class="location-badge"><i class="bi bi-tree"></i> Baguio</span>
                        <span class="location-badge"><i class="bi bi-shop"></i> Cebu</span>
                        <span class="location-badge"><i class="bi bi-wind"></i> Batanes</span>
                    </div>
                </div>
            </div>
            
            <!-- Posts will be dynamically loaded here -->
        </div>
    </div>
</div>

@section Scripts {
    <!-- MapLibre GL JS — free, open-source, no token -->
    <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
    
    <!-- TruePal App Scripts (ES6 Modules) -->
    <script type="module" src="~/js/pages/home.js" asp-append-version="true"></script>
}
