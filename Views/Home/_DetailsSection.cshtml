@model HomeViewModel

<!-- Right Half: Details Section -->
<div class="details-section">
    <div class="details-header">
        <h2 id="location-title">
            <i class="bi bi-geo-alt-fill me-2"></i>
            Explore the Philippines
        </h2>
        <p class="text-muted" id="location-subtitle">Click a location marker to discover authentic stories from locals</p>
    </div>
    
    <!-- Trending Posts Carousel -->
    <partial name="_TrendingCarousel" model="Model" />
    
    <!-- App Introduction -->
    <div class="app-intro">
        <div class="intro-content">
            <h3 class="intro-title">Discover Hidden Gems Through Local Eyes</h3>
            <p class="intro-text">
                Explore the Philippines through authentic stories shared by locals. 
                From hidden beaches to street food favorites, discover what makes each hometown special.
            </p>
            <div class="intro-highlights">
                <div class="highlight-item">
                    <i class="bi bi-people-fill"></i>
                    <span>Local Stories</span>
                </div>
                <div class="highlight-item">
                    <i class="bi bi-map-fill"></i>
                    <span>20+ Locations</span>
                </div>
                <div class="highlight-item">
                    <i class="bi bi-camera-fill"></i>
                    <span>Real Experiences</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="details-content" id="posts-container">
        <!-- Posts will be dynamically loaded here -->
    </div>
</div>
