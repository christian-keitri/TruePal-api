@model HomeViewModel

<!-- Trending Posts Slider -->
<div class="trending-carousel-container">
    <div class="trending-header">
        <h5>
            <i class="bi bi-fire me-2"></i>
            Trending Now
        </h5>
        <div class="carousel-controls">
            <button class="carousel-btn carousel-prev" aria-label="Previous">
                <i class="bi bi-chevron-left"></i>
            </button>
            <button class="carousel-btn carousel-next" aria-label="Next">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
    
    <div class="trending-carousel">
        <div class="carousel-track">
            @foreach (var post in Model.TrendingPosts)
            {
                <div class="trending-card">
                    <div class="trending-card-image" style="background-image: url('@post.ImageUrl');">
                        <div class="trending-card-overlay">
                            @if (!string.IsNullOrEmpty(post.Location))
                            {
                                <span class="location-badge">
                                    <i class="bi bi-geo-alt-fill"></i>
                                    @post.Location
                                </span>
                            }
                        </div>
                    </div>
                    <div class="trending-card-body">
                        <div class="trending-card-user">
                            <div class="trending-card-avatar">@post.Username.Substring(0, 1)</div>
                            <div>
                                <div class="trending-card-name">@post.Username</div>
                                <div class="trending-card-time">@post.TimeAgo</div>
                            </div>
                        </div>
                        <p class="trending-card-content">@post.Content</p>
                        <div class="trending-card-stats">
                            <span class="stat-item">
                                <i class="bi bi-heart-fill"></i>
                                @post.LikesCount
                            </span>
                            <span class="stat-item">
                                <i class="bi bi-chat-fill"></i>
                                @post.CommentsCount
                            </span>
                            <span class="stat-item">
                                <i class="bi bi-eye-fill"></i>
                                @post.ViewsCount
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    
    <!-- Carousel Indicators -->
    <div class="carousel-indicators" id="carousel-indicators"></div>
</div>
